# Copy this file to .env and fill in real values for local development.
# `pnpm run dev` loads this file automatically.

# --- Required ---
# Postgres connection string (same DB used by `pnpm --filter db run push`).
# This project uses Supabase Postgres. In the Supabase dashboard:
# Project Settings -> Database -> Connection string.
# Prefer the "Session pooler" string (port 5432, host like
# aws-0-<region>.pooler.supabase.com) over the direct "db.<ref>.supabase.co"
# string — the direct connection is IPv6-only unless you've bought Supabase's
# IPv4 add-on, and most local networks / Replit don't have IPv6.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Secret used to sign session cookies. Any long random string.
SESSION_SECRET=replace-with-a-long-random-string

# --- Optional: Google OAuth admin login ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of emails allowed to sign in as admin
ADMIN_EMAILS=

# --- Local dev ports (defaults shown) ---
FRONTEND_PORT=5100
API_PORT=8080
